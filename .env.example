# Copy this file to .env.local for local development.
# The local starter can create/manage this Postgres container with Docker.
DATABASE_URL=postgres://trader:trader@127.0.0.1:5432/traderloadings
LOCAL_POSTGRES_PORT=55432

BASE_PATH=/
PORT=3001
VITE_API_BASE=http://127.0.0.1:3001

# Optional integrations. Leave empty unless you are testing those flows.
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
VITE_CLERK_PUBLISHABLE_KEY=
VITE_CLERK_PROXY_URL=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
VITE_STRIPE_PUBLISHABLE_KEY=
# Webhook must subscribe: checkout.session.completed, checkout.session.async_payment_succeeded,
# customer.subscription.*, invoice.payment_succeeded/failed, charge.refunded,
# charge.dispute.created, account.updated
# Community marketplace (Stripe Connect direct charges) — dark until Connect enabled:
PLATFORM_FEE_BPS=0
OPENAI_API_KEY=
PERPLEXITY_API_KEY=
REDIS_URL=
# Myfxbook Community Outlook (retail long/short %). Without BOTH the Sentiment
# widget shows a static demo set. Account must have 2FA disabled.
MYFXBOOK_EMAIL=
MYFXBOOK_PASSWORD=

# Transactional email (support tickets). Leave RESEND_API_KEY empty to disable
# sending — the app degrades gracefully (the ticket flow still works, no email is sent).
RESEND_API_KEY=
EMAIL_FROM=TraderLoading <assistenza@traderloading.com>
# Absolute origin used in email links + logo. Local dev points at the Vite app.
APP_BASE_URL=http://127.0.0.1:5173
