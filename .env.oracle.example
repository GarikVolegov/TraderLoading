# Oracle Always Free VM deployment env
# Copy to .env.oracle and replace every placeholder, then run:
#   bash deploy/oracle/validate-env.sh

# Public domain pointed at the VM (Caddy obtains TLS automatically)
APP_DOMAIN=app.example.com

# Postgres (compose service). DATABASE_URL must embed the same password.
POSTGRES_DB=traderloading
POSTGRES_USER=traderloading
POSTGRES_PASSWORD=change-this-postgres-password
DATABASE_URL=postgresql://traderloading:change-this-postgres-password@postgres:5432/traderloading

# CORS must include the public app origin
API_CORS_ORIGINS=https://app.example.com

# Clerk auth
CLERK_PUBLISHABLE_KEY=pk_live_or_test_value
CLERK_SECRET_KEY=sk_live_or_test_value
VITE_CLERK_PUBLISHABLE_KEY=pk_live_or_test_value
VITE_CLERK_PROXY_URL=

# Frontend build args
VITE_API_BASE=

# Browser push notifications
# Generate with: pnpm push:vapid
VAPID_PUBLIC_KEY=change-this-vapid-public-key
VAPID_PRIVATE_KEY=change-this-vapid-private-key
VAPID_EMAIL=mailto:noreply@example.com
