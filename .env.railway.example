# ─────────────────────────────────────────────────────────────────────────────
# Railway (Hobby) — single-service deployment of the TraderLoadings API.
# The one service builds the frontend AND serves it + the API + WebSockets + cron.
# Set these in the Railway dashboard → service → Variables. DO NOT commit real
# values. PORT is injected by Railway automatically — do not set it.
#
# ⚠️ Variables marked [BUILD] are read at BUILD time (vite). Railway exposes
#    service variables to the build, so just set them here. Without
#    VITE_CLERK_PUBLISHABLE_KEY the frontend build fails by design (blank-screen
#    guard); set ALLOW_MISSING_CLERK_KEY=1 only for a throwaway preview.
# ─────────────────────────────────────────────────────────────────────────────

# ── Required to boot ──────────────────────────────────────────────────────────
NODE_ENV=production
# Neon POOLED connection string (host contains "-pooler"). sslmode=require.
DATABASE_URL=
# 64 hex chars: node -e "console.log(require('node:crypto').randomBytes(32).toString('hex'))"
BROKER_VAULT_KEY=
# Clerk PRODUCTION instance (custom domain, NO proxy URL — proxy caused a prod black screen).
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
VITE_CLERK_PUBLISHABLE_KEY=          # [BUILD]
# Leave EMPTY. Setting a proxy URL breaks Clerk on the custom domain.
VITE_CLERK_PROXY_URL=

# ── Persistent uploads (Railway disk is EPHEMERAL) ────────────────────────────
# Without one of the two below, avatars / chat files / local wiki uploads are
# LOST on every redeploy or restart.
# Option A (simplest): attach a Railway Volume and mount it here.
UPLOADS_DIR=/data/uploads
# Option B (scale): S3-compatible object storage (Cloudflare R2 recommended,
# egress-free). If set, leave UPLOADS_DIR for any remaining local paths.
WIKI_STORAGE_PROVIDER=               # "" (local) | "s3" | "r2"
WIKI_STORAGE_BUCKET=
WIKI_STORAGE_ENDPOINT=
WIKI_STORAGE_ACCESS_KEY_ID=
WIKI_STORAGE_SECRET_ACCESS_KEY=
WIKI_STORAGE_REGION=                 # AWS region for s3, or "auto" for R2
WIKI_STORAGE_PUBLIC_BASE_URL=

# ── URLs / CORS ───────────────────────────────────────────────────────────────
# Your public Railway domain (or custom domain), e.g. https://app.traderloading.com
APP_BASE_URL=
API_CORS_ORIGINS=                    # comma-separated allowed browser origins
VITE_API_BASE=                       # [BUILD] usually same origin; leave empty if same-origin

# ── DB pool (Neon pooler) ─────────────────────────────────────────────────────
PGPOOL_MAX=4
PGSSLMODE=require

# ── Billing (Stripe) ──────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_MONTHLY_PRICE_ID=
VITE_STRIPE_PUBLISHABLE_KEY=         # [BUILD]

# ── Web push (pnpm run push:vapid) ────────────────────────────────────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:noreply@traderloading.app

# ── Optional ──────────────────────────────────────────────────────────────────
# Redis: NOT needed on a single Hobby instance (rate-limit falls back to
# in-memory). Add an Upstash/Railway Redis URL only when you scale to >1 replica.
REDIS_URL=
# AI / search (optional features)
AI_INTEGRATIONS_OPENAI_API_KEY=
AI_INTEGRATIONS_OPENAI_BASE_URL=
PERPLEXITY_API_KEY=
# Embeddings provider for the Wiki (default off → keyword-only search)
BRAIN_EMBED_PROVIDER=
# Observability
APP_VERSION=
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.05

# ── NOT needed on Railway (drop the AWS-specific vars) ─────────────────────────
# AWS_REGION / AWS_SECRETS_MANAGER_SECRET_ID — only used by the ECS/Fargate path.
