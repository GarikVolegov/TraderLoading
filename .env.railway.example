# ─────────────────────────────────────────────────────────────────────────────
# Railway (Hobby) — single-service deployment of the TraderLoadings API.
# The one service builds the frontend AND serves it + the API + WebSockets + cron.
# Set these in the Railway dashboard → service → Variables. DO NOT commit real
# values. PORT is injected by Railway automatically — do not set it.
#
# ⚠️ Variables marked [BUILD] are read at BUILD time (vite). Railway exposes
#    service variables to the build, so just set them here. Without
#    VITE_CLERK_PUBLISHABLE_KEY the frontend build fails by design (blank-screen
#    guard); set ALLOW_MISSING_CLERK_KEY=1 only for a throwaway preview.
# ─────────────────────────────────────────────────────────────────────────────

# ── Required to boot ──────────────────────────────────────────────────────────
NODE_ENV=production
# Neon POOLED connection string (host contains "-pooler"). sslmode=require.
DATABASE_URL=
# 64 hex chars: node -e "console.log(require('node:crypto').randomBytes(32).toString('hex'))"
BROKER_VAULT_KEY=
# Clerk PRODUCTION instance (custom domain, NO proxy URL — proxy caused a prod black screen).
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
VITE_CLERK_PUBLISHABLE_KEY=          # [BUILD]
# Leave EMPTY. Setting a proxy URL breaks Clerk on the custom domain.
VITE_CLERK_PROXY_URL=

# ── Persistent uploads (Railway disk is EPHEMERAL) ────────────────────────────
# Without one of the two below, avatars / chat files / local wiki uploads are
# LOST on every redeploy or restart.
# Option A (simplest): attach a Railway Volume and mount it here.
UPLOADS_DIR=/data/uploads
# Option B (scale): S3-compatible object storage (Cloudflare R2 recommended,
# egress-free). If set, leave UPLOADS_DIR for any remaining local paths.
WIKI_STORAGE_PROVIDER=               # "" (local) | "s3" | "r2"
WIKI_STORAGE_BUCKET=
WIKI_STORAGE_ENDPOINT=
WIKI_STORAGE_ACCESS_KEY_ID=
WIKI_STORAGE_SECRET_ACCESS_KEY=
WIKI_STORAGE_REGION=                 # AWS region for s3, or "auto" for R2
WIKI_STORAGE_PUBLIC_BASE_URL=

# ── URLs / CORS ───────────────────────────────────────────────────────────────
# Your public Railway domain (or custom domain), e.g. https://app.traderloading.com
APP_BASE_URL=
API_CORS_ORIGINS=                    # comma-separated allowed browser origins
VITE_API_BASE=                       # [BUILD] usually same origin; leave empty if same-origin

# ── DB pool (Neon pooler) ─────────────────────────────────────────────────────
PGPOOL_MAX=4
PGSSLMODE=require

# ── Billing (Stripe) ──────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_MONTHLY_PRICE_ID=
VITE_STRIPE_PUBLISHABLE_KEY=         # [BUILD]
# ⚠️ The Stripe webhook (endpoint /api/billing/webhook) MUST be subscribed to these
# events or the money features silently degrade:
#   checkout.session.completed          → grant credits (B) / activate Pro
#   charge.refunded, charge.dispute.created → claw back refunded/disputed credits (anti-fraud)
#   account.updated                     → sync Connect payout capability (D)
#   customer.subscription.*, invoice.*  → Pro subscription lifecycle

# ── Community credits (sub-project B) — dark until the pack Price IDs are set ──
STRIPE_CREDIT_PRICE_STARTER=         # Stripe Price id (one-time) for the 100-credit pack
STRIPE_CREDIT_PRICE_PLUS=            # …500-credit pack
STRIPE_CREDIT_PRICE_PRO=             # …1200-credit pack

# ── Creator payout (sub-project D) — dark until PAYOUT_CREDIT_CENTS is set. ────
# Requires Stripe CONNECT enabled on the account. TEST in test-mode Connect first.
PAYOUT_CREDIT_CENTS=                 # payout-currency cents per 1 credit (e.g. 1 ⇒ 1 credit = €0.01). UNSET ⇒ payouts OFF
PAYOUT_MIN_CREDITS=1000              # minimum credits per cash-out request
PAYOUT_FEE_BPS=0                     # platform fee, basis points of gross (0–9999)
PAYOUT_CURRENCY=eur                  # 2-decimal currency only (jpy/etc. auto-disable payouts)

# ── Web push (pnpm run push:vapid) ────────────────────────────────────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:noreply@traderloading.app

# ── Transactional email — Resend (support tickets) ────────────────────────────
# Optional: leave RESEND_API_KEY empty to disable email (ticket flow still works).
# EMAIL_FROM must be on a domain whose SPF/DKIM are verified in Resend, or delivery
# silently fails. APP_BASE_URL (above) is used for email links + the logo image.
RESEND_API_KEY=
EMAIL_FROM=TraderLoading <assistenza@traderloading.com>
# Lifecycle emails (welcome / weekly digest / win-back) run as a daily cron but
# stay DARK until you opt in. Set to 1 only after verifying deliverability with a
# test send — needs RESEND_API_KEY above. Leave empty to keep them off.
EMAIL_LIFECYCLE_ENABLED=

# ── Optional ──────────────────────────────────────────────────────────────────
# Redis: NOT needed on a single Hobby instance (rate-limit falls back to
# in-memory). Add an Upstash/Railway Redis URL only when you scale to >1 replica.
# When you DO scale out, set EXPECTED_REPLICAS to the replica count: the server
# then refuses to boot without REDIS_URL (per-process rate limits/cron would be
# wrong across replicas). Left unset/1, a single instance boots and just warns.
REDIS_URL=
EXPECTED_REPLICAS=1
# AI / LLM (optional). News sentiment ranking + Wiki PDF/image OCR use an
# OpenAI-compatible LLM. Provider selectable via BRAIN_LLM_PROVIDER (default:
# openrouter). Leave the key empty to disable these features (graceful degrade).
BRAIN_LLM_PROVIDER=                   # "" → openrouter | groq | local
OPENROUTER_API_KEY=                   # required when provider=openrouter (default)
GROQ_API_KEY=                         # required when provider=groq
BRAIN_LLM_BASE_URL=                   # optional endpoint override
BRAIN_TEXT_MODEL=                     # optional model override (text)
BRAIN_VISION_MODEL=                   # optional model override (vision/OCR)
# Perplexity (optional) — COT / web-search tools in routes/tools.ts.
PERPLEXITY_API_KEY=
# AI avatar generation (optional) — profile "generate AI avatar" via an
# OpenAI-compatible image endpoint (lib/integrations-openai-ai-server).
AI_INTEGRATIONS_OPENAI_BASE_URL=
AI_INTEGRATIONS_OPENAI_API_KEY=
# Retail sentiment — Myfxbook Community Outlook (optional, recommended).
# Without BOTH vars the "Sentiment" widget (/tools/sentiment) shows a STATIC DEMO
# set labelled "Dati dimostrativi". Set a Myfxbook account login here for LIVE
# long/short %. The account must have 2FA DISABLED — the API logs in with
# email+password only. Server-side only (NOT a [BUILD] var); session cached ~55m.
MYFXBOOK_EMAIL=
MYFXBOOK_PASSWORD=

# ── Platform admin (comma-separated Clerk user IDs) ───────────────────────────
# Without these, admin / curation features are unreachable in production.
ADMIN_BOOTSTRAP_USER_IDS=            # seeds admin_permissions on boot
PLATFORM_ADMIN_IDS=                  # gates library + milestones curation
# Observability (Sentry — org "gazz", EU region). DSNs are public (they ship in the
# client bundle / are used by the SDK); the auth token is a SECRET.
APP_VERSION=                          # backend release; also set VITE_APP_VERSION for the frontend
VITE_APP_VERSION=                     # frontend release name (e.g. git SHA) — ties errors to a sourcemap upload
SENTRY_DSN=https://bd4cb313aaa22f1ec44084e955aef1d5@o4511384832770048.ingest.de.sentry.io/4511688567095376        # backend project: api-server
VITE_SENTRY_DSN=https://ea9437058624b8cddfc9fa58665b1b7f@o4511384832770048.ingest.de.sentry.io/4511688516567120   # frontend project: trader-dashboard (build-time)
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.05
# Frontend sourcemap upload — runs during the build ONLY when SENTRY_AUTH_TOKEN is set:
SENTRY_ORG=gazz
SENTRY_PROJECT=trader-dashboard
SENTRY_URL=https://de.sentry.io       # EU region control silo (org is on de.sentry.io)
SENTRY_AUTH_TOKEN=                    # SECRET — user auth token with project:releases scope; set in Railway, never commit

# ── Tornei: conio certificati NFT (opzionale) ─────────────────────────────────
# Lascia vuoto per tenere i certificati "claimable" (nessun conio on-chain).
# Quando tutte e tre sono impostate, i certificati vengono coniati su Base (ERC-721).
# La SIGNER_KEY è un segreto: NON committarla. Chain id default 8453 (Base mainnet).
TORNEI_MINT_RPC_URL=
TORNEI_MINT_CONTRACT=
TORNEI_MINT_SIGNER_KEY=
TORNEI_MINT_CHAIN_ID=8453

# ── NOT needed on Railway (drop the AWS-specific vars) ─────────────────────────
# AWS_REGION / AWS_SECRETS_MANAGER_SECRET_ID — only used by the ECS/Fargate path.
