FROM node:24-bookworm-slim AS base

ENV PNPM_HOME="/pnpm"
ENV PATH="$PNPM_HOME:$PATH"

RUN corepack enable && corepack prepare pnpm@11.0.9 --activate

WORKDIR /app

FROM base AS deps

COPY package.json pnpm-lock.yaml pnpm-workspace.yaml tsconfig.json tsconfig.base.json ./
COPY artifacts/api-server/package.json artifacts/api-server/package.json
COPY artifacts/trader-dashboard/package.json artifacts/trader-dashboard/package.json
COPY lib/api-client-react/package.json lib/api-client-react/package.json
COPY lib/api-spec/package.json lib/api-spec/package.json
COPY lib/api-zod/package.json lib/api-zod/package.json
COPY lib/db/package.json lib/db/package.json
COPY lib/integrations-openai-ai-server/package.json lib/integrations-openai-ai-server/package.json
COPY lib/pair-catalog/package.json lib/pair-catalog/package.json
COPY lib/replit-auth-web/package.json lib/replit-auth-web/package.json
COPY scripts/package.json scripts/package.json

RUN pnpm install --frozen-lockfile

FROM deps AS build

ARG VITE_CLERK_PUBLISHABLE_KEY
ARG VITE_CLERK_PROXY_URL
ARG VITE_API_BASE

ENV VITE_CLERK_PUBLISHABLE_KEY=$VITE_CLERK_PUBLISHABLE_KEY
ENV VITE_CLERK_PROXY_URL=$VITE_CLERK_PROXY_URL
ENV VITE_API_BASE=$VITE_API_BASE

COPY . .

RUN pnpm run build:railway
RUN pnpm prune --prod

FROM node:24-bookworm-slim AS runtime

ENV NODE_ENV=production
ENV PORT=3001
ENV FRONTEND_DIST_DIR=/app/artifacts/trader-dashboard/dist/public

WORKDIR /app

RUN useradd --system --uid 10001 --create-home --home-dir /home/trader trader \
  && mkdir -p /app/artifacts/api-server/uploads \
  && chown -R trader:trader /app

COPY --from=build --chown=trader:trader /app/artifacts/api-server/dist /app/artifacts/api-server/dist
COPY --from=build --chown=trader:trader /app/artifacts/trader-dashboard/dist /app/artifacts/trader-dashboard/dist
COPY --from=build --chown=trader:trader /app/node_modules /app/node_modules
COPY --from=build --chown=trader:trader /app/package.json /app/package.json
COPY --from=build --chown=trader:trader /app/artifacts/api-server/package.json /app/artifacts/api-server/package.json
COPY --from=build --chown=trader:trader /app/artifacts/api-server/node_modules /app/artifacts/api-server/node_modules

WORKDIR /app/artifacts/api-server

EXPOSE 3001

HEALTHCHECK --interval=30s --timeout=5s --start-period=60s --retries=3 \
  CMD node -e "fetch('http://127.0.0.1:3001/api/healthz').then((r)=>process.exit(r.ok?0:1)).catch(()=>process.exit(1))"

USER trader

CMD ["node", "./dist/index.cjs"]
