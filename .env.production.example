# Production database
# Use the pooled Neon connection string in deployed/serverless environments when available.
# Example format:
# DATABASE_URL=postgresql://USER:PASSWORD@ep-example-pooler.REGION.aws.neon.tech/DATABASE?sslmode=verify-full&channel_binding=require
NODE_ENV=production
DATABASE_URL=
PORT=

# PostgreSQL pool sizing. For Neon pooled connections, keep this low enough that
# PGPOOL_MAX * task/instance count stays below your plan's pooled connection cap.
PGPOOL_MAX=4
PG_IDLE_TIMEOUT_MS=30000
PG_CONNECTION_TIMEOUT_MS=5000
# Use require for AWS RDS with the proper CA bundle. Use no-verify only as a
# temporary bridge when the CA bundle cannot be installed yet.
PGSSLMODE=require
PG_ALLOW_EXIT_ON_IDLE=

# Railway single-service deployment
# Leave FRONTEND_DIST_DIR empty unless you override the monorepo build layout.
FRONTEND_DIST_DIR=
API_CORS_ORIGINS=
VITE_API_BASE=
APP_BASE_URL=
UPLOADS_DIR=

# Brain AI Wiki storage
# Default is local filesystem storage under UPLOADS_DIR/wiki.
# Use "s3" for AWS S3 or "r2" for Cloudflare R2/S3-compatible storage.
WIKI_STORAGE_PROVIDER=
WIKI_STORAGE_BUCKET=
WIKI_STORAGE_ENDPOINT=
WIKI_STORAGE_ACCESS_KEY_ID=
WIKI_STORAGE_SECRET_ACCESS_KEY=
# Use an AWS region for S3, or "auto" for Cloudflare R2.
WIKI_STORAGE_REGION=
# Optional public CDN/base URL for stored wiki files.
WIKI_STORAGE_PUBLIC_BASE_URL=

# Optional production integrations
PERPLEXITY_API_KEY=
AI_INTEGRATIONS_OPENAI_BASE_URL=
AI_INTEGRATIONS_OPENAI_API_KEY=

# Stripe Billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_MONTHLY_PRICE_ID=
VITE_STRIPE_PUBLISHABLE_KEY=

# Auth
# Use the Clerk production app configured with Google custom OAuth credentials
# and TraderLoading branding. See docs/deploy/google-oauth-traderloading-branding.md.
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
VITE_CLERK_PUBLISHABLE_KEY=
VITE_CLERK_PROXY_URL=

# OIDC/mobile auth
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
ISSUER_URL=
MOBILE_REDIRECT_URIS=
PLATFORM_ADMIN_IDS=

# Broker/account secrets
# Generate a 32-byte key as 64 hex chars:
#   node -e "console.log(require('node:crypto').randomBytes(32).toString('hex'))"
# In AWS, store this in Secrets Manager or SSM Parameter Store and inject it
# into the task/container environment as BROKER_VAULT_KEY.
BROKER_VAULT_KEY=

# AWS production secret-management reference
AWS_REGION=
AWS_SECRETS_MANAGER_SECRET_ID=
REDIS_URL=

# Observability and error tracking
APP_VERSION=
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.05
DD_SERVICE=traderloadings-api
DD_API_KEY=
NEW_RELIC_APP_NAME=TraderLoadings API
NEW_RELIC_LICENSE_KEY=

# Browser push notifications
# Generate with: pnpm run push:vapid
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:noreply@traderloading.app
