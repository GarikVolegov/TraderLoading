{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "preinstall": "node -e \"const fs=require('node:fs'); for (const file of ['package-lock.json','yarn.lock']) fs.rmSync(file,{force:true}); const ua=process.env.npm_config_user_agent||''; const execPath=process.env.npm_execpath||''; if (!ua.startsWith('pnpm/') && !execPath.includes('pnpm')) { console.error('Use pnpm instead'); process.exit(1); }\"",
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "typecheck:libs": "tsc --build --force",
    "typecheck": "pnpm --filter ./scripts exec tsx local/typecheck.ts",
    "codegen": "pnpm --filter @workspace/api-spec run codegen",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "pnpm --filter ./scripts exec tsx local/run-tests.ts",
    "verify": "pnpm --filter ./scripts exec tsx local/verify.ts",
    "verify:runtime": "pnpm --filter ./scripts exec tsx local/verify-runtime.ts",
    "smoke:runtime": "pnpm --filter ./scripts exec tsx local/runtime-smoke.ts",
    "start:local": "pnpm --filter ./scripts exec tsx local/start.ts",
    "build:railway": "pnpm --filter @workspace/trader-dashboard build && pnpm --filter @workspace/api-server build",
    "start:railway": "pnpm --filter @workspace/api-server start",
    "db:generate": "pnpm --filter @workspace/db generate",
    "db:migrate": "pnpm --filter @workspace/db migrate",
    "db:push": "pnpm --filter @workspace/db push",
    "push:vapid": "pnpm --filter @workspace/api-server exec web-push generate-vapid-keys"
  },
  "private": true,
  "devDependencies": {
    "eslint": "^9",
    "eslint-config-prettier": "^9",
    "eslint-plugin-react-hooks": "^5",
    "globals": "^15",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8"
  },
  "packageManager": "pnpm@9.12.0+sha512.4abf725084d7bcbafbd728bfc7bee61f2f791f977fd87542b3579dcb23504d170d46337945e4c66485cd12d588a0c0e570ed9c477e7ccdd8507cf05f3f92eaca"
}
