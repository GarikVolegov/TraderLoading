{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "App: start local stack",
      "type": "node-terminal",
      "request": "launch",
      "command": "pnpm run start:local",
      "cwd": "${workspaceFolder}",
      "serverReadyAction": {
        "pattern": "TraderLoadings is running at (http://localhost:5173)",
        "uriFormat": "%s",
        "action": "openExternally"
      }
    },
    {
      "name": "Browser: debug Vite app",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}/artifacts/trader-dashboard",
      "sourceMaps": true,
      "sourceMapPathOverrides": {
        "vite:///*": "${webRoot}/*",
        "webpack:///*": "${webRoot}/*",
        "/*": "${webRoot}/*"
      }
    },
    {
      "name": "API: debug local server",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "runtimeExecutable": "node",
      "runtimeArgs": [
        "--import",
        "tsx",
        "--inspect=9229"
      ],
      "program": "${workspaceFolder}/scripts/local/startApiDev.ts",
      "env": {
        "BASE_PATH": "/",
        "NODE_ENV": "development",
        "PORT": "3001"
      },
      "console": "integratedTerminal",
      "skipFiles": [
        "<node_internals>/**"
      ]
    },
    {
      "name": "Frontend: Vite dev server",
      "type": "node-terminal",
      "request": "launch",
      "command": "pnpm --filter @workspace/trader-dashboard run dev",
      "cwd": "${workspaceFolder}",
      "env": {
        "BASE_PATH": "/",
        "PORT": "5173",
        "VITE_API_BASE": "http://127.0.0.1:3001"
      },
      "serverReadyAction": {
        "pattern": "Local:\\s+(http://localhost:5173/?)",
        "uriFormat": "%s",
        "action": "openExternally"
      }
    }
  ],
  "compounds": [
    {
      "name": "Debug: full app",
      "configurations": [
        "App: start local stack",
        "Browser: debug Vite app"
      ],
      "stopAll": true
    }
  ]
}
